
{
  "name": "KEITH-MD",
  "description": "This is a simple whatsapp bot built with nodejs to make your WhatsApp enjoyable",
  "keywords": [
    "bot",
    "whatsapp",
    "keith",
    "whatsapp-stickers",
    "anime",
    "whatsapp-bot",
    "whatsapp-sticker-bot",
    "whatsapp-botto",
    "baileys",
    "baileys-md",
    "md-bot"
  ],
  "website": "https://keithsite.top",
  "repository": "https://github.com/kkeizzah25/KEITH-MD.git",
  "logo": "https://i.ibb.co/PsZnb9NH/0d81ac6b1fb1.jpg",
  "success_url": "/",
  "env": {
    "OWNER_NUMBER": {
      "description": "Bot owner phone number without + or spaces. Example: 254748387615, 254796299159",
      "required": false
    },
    "SESSION": {
      "description": "Your WhatsApp session ID",
      "required": true
    },
     
    "DATABASE_URL": {
      "description": "insert your database url",
      "value": "",
      "required": false
    },
    
    "AUTOVIEW_STATUS": {
      "description": "Auto view WhatsApp status (true/false)",
      "value": "true",
      "required": false
    },
    "AUTOLIKE_STATUS": {
      "description": "Auto like WhatsApp status (true/false)",
      "value": "true",
      "required": false
    },
    "STATUS_LIKE_EMOJIS": {
      "description": "Emojis to use for liking status (comma-separated)",
      "value": "💚,🫟",
      "required": false
    },
    
    "PREFIX": {
      "description": "Bot command prefix",
      "value": ".",
      "required": false
    },
    
    "BOT_EXPIRATION_DATE": {
      "description": "choose your preferred bot expiration date in the format dd/mm/yy",
      "value": "11/03/2027",
      "required": false
    },
    
    "BOT_PIC": {
      "description": "Bot profile picture URL",
      "value": "https://i.ibb.co/PsZnb9NH/0d81ac6b1fb1.jpg",
      "required": false
    },
    "BOTNAME": {
      "description": "Bot display name",
      "value": "KEITH-MD",
      "required": false
    },
    "AUTO_SOCIAL_DOWNLOAD": {
      "description": "when enabled true bot will automatically download social media videos when you share the url example for tiktok instagram youtube and many more",
      "value": "false",
      "required": false
    },
    "OWNER_NAME": {
      "description": "your botname",
      "value": "Keith",
      "required": false
    },
    "MODE": {
      "description": "Bot operation mode (public/private)",
      "value": "public",
      "required": false
    }
  },
  "buildpacks": [
    {
      "url": "https://github.com/heroku/heroku-buildpack-nodejs.git"
    }
  ],
  "stack": "heroku-24"
}
